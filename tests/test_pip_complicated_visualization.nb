Notebook[{
Cell["This notebook visualizes the polygon used in the test case, the query points used in the test case, the query-to-perturbed-antipode arcs, and that it is the visualization companion for the C++ test in tests/. In particular, it is the visualization companion for tests/test_pip_complicated.cpp.", "Text"],
Cell["ClearAll[\"Global`*\"];\n\nlonLatToXYZ[{lon_, lat_}] := Module[\n  {lam = lon Degree, phi = lat Degree},\n  {\n    Cos[phi] Cos[lam],\n    Cos[phi] Sin[lam],\n    Sin[phi]\n  }\n];\n\nmakePerturbedAntipode[q_] := Module[\n  {r, ax, ay, az, eps = 10^-8, n2, invn},\n  r = -q;\n\n  ax = Abs[r[[1]]];\n  ay = Abs[r[[2]]];\n  az = Abs[r[[3]]];\n\n  If[ax <= ay && ax <= az,\n    r[[1]] += eps,\n    If[ay <= ax && ay <= az,\n      r[[2]] += eps,\n      r[[3]] += eps\n    ]\n  ];\n\n  n2 = r[[1]]^2 + r[[2]]^2 + r[[3]]^2;\n  If[n2 > 0,\n    invn = 1/Sqrt[n2];\n    r = invn r;\n  ];\n\n  N[r, 30]\n];\n\n(* ------------------------------------------------ *)\n(* Reference q and its great-circle plane           *)\n(* ------------------------------------------------ *)\n\nqRef = N[lonLatToXYZ[{-41, 0}], 30];\nrRef = makePerturbedAntipode[qRef];\n\nn = Normalize[Cross[qRef, rRef]];\n\nseed = {0, 0, 1};\nIf[Norm[Cross[n, seed]] < 10^-12, seed = {1, 0, 0}];\n\nu = Normalize[Cross[n, seed]];\nv = Normalize[Cross[n, u]];\n\nthetaQ = ArcTan[qRef . u, qRef . v];\n\nmakeOnPlane[theta_] := N[Cos[theta] u + Sin[theta] v, 30];\n\nmakeOffPlane[theta_, h_] := N[\n  Normalize[Cos[theta] u + Sin[theta] v + h n],\n  30\n];\n\nmakeQueryPoint[theta_, h_] := N[\n  Normalize[Cos[theta] u + Sin[theta] v + h n],\n  30\n];\n\n(* ------------------------------------------------ *)\n(* Degenerate backbone                              *)\n(* ------------------------------------------------ *)\n\ndeltaP8 = 0.5 Degree;\ndeltaP7 = 8 Degree;\ndeltaP5 = 16 Degree;\ndeltaP3 = 24 Degree;\n\nthetaP8 = thetaQ - deltaP8;\nthetaP7 = thetaQ + deltaP7;\nthetaP5 = thetaQ + deltaP5;\nthetaP3 = thetaQ + deltaP3;\n\nP8 = makeOnPlane[thetaP8];\nP7 = makeOnPlane[thetaP7];\nP5 = makeOnPlane[thetaP5];\nP3 = makeOnPlane[thetaP3];\n\n(* ------------------------------------------------ *)\n(* Remaining vertices                               *)\n(* ------------------------------------------------ *)\n\nP2 = makeOffPlane[thetaP3 + 6 Degree, +0.28];\nP1 = makeOffPlane[thetaP3 + 18 Degree, -0.42];\n\nP6 = makeOffPlane[thetaP7 + 4 Degree, -0.33];\nP4 = makeOffPlane[thetaP5 - 4 Degree, +0.28];\n\nP9  = makeOffPlane[thetaP8 - 10 Degree, +0.34];\nP10 = makeOffPlane[thetaP8 - 28 Degree, -0.42];\nP11 = makeOffPlane[thetaP8 - 40 Degree, -0.30];\nP12 = makeOffPlane[thetaP8 - 58 Degree, -0.38];\n\npolyNames = {\"P1\", \"P2\", \"P3\", \"P4\", \"P5\", \"P6\", \"P7\", \"P8\", \"P9\", \"P10\", \"P11\", \"P12\"};\npolyPts = {P1, P2, P3, P4, P5, P6, P7, P8, P9, P10, P11, P12};\n\n(* ------------------------------------------------ *)\n(* Actual query points Q1..Q6                       *)\n(* ------------------------------------------------ *)\n\nthetaQ1 = thetaQ - 3.0 Degree;\nthetaQ2 = (thetaP8 + thetaP7)/2;\nthetaQ3 = (thetaP7 + thetaP5)/2;\nthetaQ4 = (thetaP5 + thetaP3)/2;\n\nQ1 = makeQueryPoint[thetaQ1, 0.0];\nQ2 = makeOffPlane[thetaP7 - 4 Degree, -0.33];\nQ3 = makeOffPlane[thetaP5 - 6 Degree, +0.28];\nQ4 = makeQueryPoint[thetaP3, +0.08];\nQ5 = P9;\nQ6 = makeQueryPoint[thetaQ2, 0.0];\n\n(* Q5 lies exactly on a polygon vertex. *)\n(* Q6 lies on a polygon edge (great-circle arc). *)\n\nR1 = makePerturbedAntipode[Q1];\nR2 = makePerturbedAntipode[Q2];\nR3 = makePerturbedAntipode[Q3];\nR4 = makePerturbedAntipode[Q4];\nR5 = makePerturbedAntipode[Q5];\nR6 = makePerturbedAntipode[Q6];\n\nqueryNames = {\"Q1\", \"Q2\", \"Q3\", \"Q4\", \"Q5\", \"Q6\"};\nqueryPts = {Q1, Q2, Q3, Q4, Q5, Q6};\n\nrNames = {\"R1\", \"R2\", \"R3\", \"R4\", \"R5\", \"R6\"};\nrPts = {R1, R2, R3, R4, R5, R6};\n\nPrint[\"Polygon vertices XYZ:\"];\nDo[\n  Print[polyNames[[i]], \" = \", NumberForm[polyPts[[i]], {Infinity, 17}]],\n  {i, Length[polyPts]}\n];\n\nPrint[\" \"];\nPrint[\"Query points and perturbed antipodes XYZ:\"];\nDo[\n  Print[queryNames[[i]], \" = \", NumberForm[queryPts[[i]], {Infinity, 17}]];\n  Print[rNames[[i]], \" = \", NumberForm[rPts[[i]], {Infinity, 17}]];\n  Print[\" \"];\n  ,\n  {i, Length[queryPts]}\n];\n\n\ngcaMinorPoints[a_, b_, npts_:100] := Module[\n  {aa, bb, dot, theta, ts, normal, u0, v0},\n\n  aa = N[a/Norm[a], 30];\n  bb = N[b/Norm[b], 30];\n\n  dot = Clip[aa . bb, {-1, 1}];\n  theta = ArcCos[dot];\n\n  normal = Normalize[Cross[aa, bb]];\n  u0 = aa;\n  v0 = Normalize[Cross[normal, u0]];\n  ts = N[Range[0, npts]/npts, 30];\n\n  Table[\n    Normalize[Cos[t theta] u0 + Sin[t theta] v0],\n    {t, ts}\n  ]\n];\n\npolyEdges = Partition[Append[polyPts, First[polyPts]], 2, 1];\n\npolyEdgeArcs = Table[\n  gcaMinorPoints[polyEdges[[i, 1]], polyEdges[[i, 2]], 100],\n  {i, Length[polyEdges]}\n];\n\nqueryRayArcs = Table[\n  gcaMinorPoints[queryPts[[i]], rPts[[i]], 180],\n  {i, Length[queryPts]}\n];\n\nGraphics3D[\n {\n   {Opacity[0.025], LightGray, Sphere[{0, 0, 0}, 1]},\n\n   (* polygon edges as GCAs *)\n   {Blue, Thick,\n    Table[\n      Line[polyEdgeArcs[[i]]],\n      {i, Length[polyEdgeArcs]}\n    ]\n   },\n\n   (* Q_i -> R_i as dashed GCAs *)\n   {Directive[Dashed, Darker[Gray], Thick],\n    Table[\n      Line[queryRayArcs[[i]]],\n      {i, Length[queryRayArcs]}\n    ]\n   },\n\n   {Darker[Gray],\n    Table[\n      Arrow[queryRayArcs[[i]][[-8 ;; -1]]],\n      {i, Length[queryRayArcs]}\n    ]\n   },\n\n   {Red, PointSize[0.028], Point[polyPts]},\n   {Darker[Green], PointSize[0.032], Point[queryPts]},\n   {Purple, PointSize[0.030], Point[rPts]},\n\n   Table[\n     Text[\n       Style[polyNames[[i]], 16, Bold, Black],\n       1.08 polyPts[[i]]\n     ],\n     {i, Length[polyPts]}\n   ],\n\n   Table[\n     Text[\n       Style[queryNames[[i]], 15, Bold, Darker[Green]],\n       1.08 queryPts[[i]]\n     ],\n     {i, Length[queryPts]}\n   ],\n\n   Table[\n     Text[\n       Style[rNames[[i]], 15, Bold, Purple],\n       1.08 rPts[[i]]\n     ],\n     {i, Length[rPts]}\n   ]\n },\n Boxed -> False,\n Axes -> False,\n Lighting -> \"Neutral\",\n SphericalRegion -> True,\n ViewPoint -> {2.2, -2.1, 1.6},\n ImageSize -> Large,\n PlotRange -> All\n]\n", "Input"]
},
WindowSize->{808, 911},
WindowMargins->{{Automatic, 72}, {Automatic, 37}},
StyleDefinitions->"Default.nb"
]
